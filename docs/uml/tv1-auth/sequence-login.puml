@startuml sequence-login
actor Browser
participant AuthController
participant AuthService
participant UserRepository
participant JwtTokenProvider

Browser -> AuthController: POST /api/auth/login
AuthController -> AuthService: login(email, password)
AuthService -> UserRepository: findByEmail(email)
UserRepository --> AuthService: User
AuthService -> AuthService: BCrypt.matches(password, hash)
AuthService -> JwtTokenProvider: generateToken(email)
JwtTokenProvider --> AuthService: JWT token
AuthService --> AuthController: AuthResponse(token, role)
AuthController --> Browser: 200 OK + AuthResponse
@enduml
